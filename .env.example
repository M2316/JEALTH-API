# Gemini API
GEMINI_API_KEY=                        # Google AI Studio 발급 키 (커밋 금지)
GEMINI_MODEL=gemini-2.5-flash          # 기본 모델. 정확도 필요 시 gemini-2.5-pro
GEMINI_INFER_MODEL=gemini-3-pro-preview # 신규 운동 근육 그룹 추론 (Pro 모델)
GEMINI_TIMEOUT_MS=15000                # 호출 타임아웃 (ms)
GEMINI_MAX_OUTPUT_TOKENS=512           # 응답 토큰 상한 (비용 안전망)
EXERCISE_RAG_TOP_K=10                  # pg_trgm 유사도 검색 후보 개수
EXERCISE_RAG_MIN_SIMILARITY=0.1        # pg_trgm 유사도 임계값 (0~1, 높을수록 엄격)
